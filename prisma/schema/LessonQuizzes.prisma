model LessonQuizzes {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  lessonId     String   @unique @db.ObjectId
  title        String
  kind         QuizKind @default(quiz)
  passingScore Int      @default(70)
  gradeStrategy QuizGradeStrategy? @default(highest)
  isGradable   Boolean  @default(true)
  isPublished  Boolean  @default(false)
  timeLimitMinutes Int?
  maxAttempts     Int?
  availableFrom   DateTime?
  availableUntil  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lesson    CourseLessons  @relation(fields: [lessonId], references: [id])
  questions QuizQuestions[]
  attempts  QuizAttempts[]

  @@map("lesson_quizzes")
}

model QuizQuestions {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  quizId        String   @db.ObjectId
  prompt        String
  type          QuizQuestionType @default(single_choice)
  options       String[]
  correctOption Int
  correctOptions Int[] @default([])
  acceptedAnswers String[] @default([])
  caseSensitive Boolean @default(false)
  points        Int @default(1)
  explanation   String?
  order         Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  quiz LessonQuizzes @relation(fields: [quizId], references: [id])

  @@index([quizId, order])
  @@map("quiz_questions")
}

model QuizAttempts {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  quizId    String   @db.ObjectId
  userId    String   @db.ObjectId
  status    QuizAttemptStatus @default(graded)
  score     Int
  passed    Boolean
  answers   Int[]
  responses Json?
  grading Json?
  feedback String?
  earnedPoints Float @default(0)
  totalPoints Float @default(0)
  startedAt DateTime @default(now())
  expiresAt DateTime?
  submittedAt DateTime?
  gradedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quiz LessonQuizzes @relation(fields: [quizId], references: [id])
  user Users         @relation(fields: [userId], references: [id])

  @@index([quizId, userId, createdAt])
  @@index([userId, createdAt])
  @@map("quiz_attempts")
}

enum QuizKind {
  quiz
  exam
}

enum QuizGradeStrategy {
  highest
  latest
  average
  first
}

enum QuizQuestionType {
  single_choice
  multiple_choice
  true_false
  short_answer
  long_answer
}

enum QuizAttemptStatus {
  in_progress
  submitted
  timed_out
  pending_review
  graded
}
