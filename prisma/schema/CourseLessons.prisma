model CourseLessons {
  id             String             @id @default(auto()) @map("_id") @db.ObjectId
  sectionId      String             @db.ObjectId
  name           String
  description    String?
  type           CourseLessonType   @default(video)
  content        String             @default("")
  youtubeVideoId String             @default("")
  transcript     String             @default("")
  status         CourseLessonStatus @default(private)
  order          Int
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  section            CourseSections       @relation(fields: [sectionId], references: [id])
  userLessonComplete UserLessonComplete[]
  userLessonProgress UserLessonProgress[]
  lessonNotes        LessonNotes[]
  lessonBookmarks    LessonBookmarks[]
  quiz               LessonQuizzes?

  @@index([sectionId, order])
  @@index([status])
  @@map("course_lessons")
}

enum CourseLessonStatus {
  public
  private
  preview
}

enum CourseLessonType {
  video
  text
  quiz
}
